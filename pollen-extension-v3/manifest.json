{
  "manifest_version": 3,
  "name": "花粉チェッカー Pro",
  "version": "3.0",
  "description": "スギ・ヒノキ対応。市区町村名で今日の花粉量をチェック",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://nominatim.openstreetmap.org/*",
    "https://pollen.googleapis.com/*"
  ]
}
