{
  "manifest_version": 3,
  "name": "Chatwork Attendance Tracker",
  "version": "1.0",
  "description": "Chatworkから勤怠時間を取得・表示",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://www.chatwork.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.chatwork.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-script.js"],
      "matches": ["https://www.chatwork.com/*"]
    }
  ]
}
